services:
  backend:
    build: ./backend
    expose:
      - 8000
    env_file:
      - ./backend/.env
    restart: always

  frontend:
    build: ./frontend
    expose:
      - 3000
    restart: always
    depends_on:
      - backend
    volumes:
      - ./frontend:/app/frontend
      - /app/frontend/node_modules
    networks:
      - lan00
      - dmz00

networks:
  lan00:
    name: lan00
    external: true
  dmz00:
    name: dmz00
    external: true