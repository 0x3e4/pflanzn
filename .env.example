# ── General ──────────────────────────────────────────────
SECRET_KEY=change_me
VITE_TZ=UTC
VITE_LOCALE=en-US
VITE_DOMAIN=

# ── Authentication ───────────────────────────────────────
# Modes: "no" (open), "local" (JWT), "oidc" (external provider)
VITE_AUTH_MODE=no
VITE_SHOW_PROTECTED_VIEW=true
ADMIN_USER=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── OIDC (only when VITE_AUTH_MODE=oidc) ─────────────────
VITE_OIDC_NAME=
OIDC_PROVIDER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── Database (MariaDB) ──────────────────────────────────
DB_HOST=pflanzn-mariadb-1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=***REDACTED***
DB_ROOT_PASSWORD=
DB_NAME=plants_db

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://pflanzn-redis-1:6379/0

# ── Features ─────────────────────────────────────────────
VITE_ENABLE_LOCATIONS=false

# ── PlantNet (species identification) ────────────────────
PLANTNET_API_KEY=
PLANTNET_LANGUAGE=en

# ── AI / LLM (care advice) ──────────────────────────────
# Provider: openai, claude, mistral, huggingface, ollama
VITE_LLM_PROVIDER=
LLM_LANGUAGE=german

OPENAI_API_KEY=
OPENAI_MODEL_NAME=

CLAUDE_API_KEY=
CLAUDE_MODEL_NAME=

MISTRALAI_API_KEY=
MISTRALAI_API_URL=
MISTRALAI_MODEL_NAME=

HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL_NAME=

OLLAMA_URL=
OLLAMA_MODEL_NAME=

# ── Weather (auto-watering) ──────────────────────────────
# Uses Open-Meteo (free, no key) by default.
# Optionally set an OpenWeatherMap key for current weather display.
WEATHER_ENABLED=true
WEATHER_CHECK_INTERVAL_HOURS=1
WEATHER_RAINFALL_THRESHOLD_MM=10.0
OPENWEATHERMAP_API_KEY=
