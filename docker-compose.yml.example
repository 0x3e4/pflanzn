services:
  backend:
    image: ghcr.io/0x3e4/pflanzn-backend:latest
    ports:
      - "8000:8000"
    env_file:
      - .env
    volumes:
      - ./backend:/backend
    depends_on:
      redis:
        condition: service_started
      mariadb:
        condition: service_healthy
    restart: always

  frontend:
    image: ghcr.io/0x3e4/pflanzn-frontend:latest
    environment:
      DOMAIN: ${DOMAIN}
    ports:
      - "4173:4173"
    env_file:
      - .env
    restart: always
    depends_on:
      - mariadb
      - backend

  mariadb:
    image: mariadb:latest
    restart: always
    environment:
      MARIADB_ROOT_PASSWORD: ${DB_ROOT_PASSWORD}
      MARIADB_DATABASE: ${DB_NAME}
      MARIADB_USER: ${DB_USER}
      MARIADB_PASSWORD: ${DB_PASSWORD}
    volumes:
      - mariadb_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mariadb-admin", "ping", "-h", "localhost", "-u", "root", "-p***REDACTED***"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s

  redis:
    image: redis:latest
    restart: always

volumes:
  mariadb_data:
