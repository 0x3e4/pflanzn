services:
  backend:
    image: ghcr.io/0x3e4/pflanzn-backend:latest
    pull_policy: always
    ports:
      - "8000:8000"
    env_file:
      - .env
    volumes:
      - ./backend/app/uploads:/backend/app/uploads
    depends_on:
      redis:
        condition: service_started
      mariadb:
        condition: service_healthy
    restart: always
    networks:
      - default
      - db

  frontend:
    image: ghcr.io/0x3e4/pflanzn-frontend:latest
    pull_policy: always
    environment:
      DOMAIN: ${DOMAIN}
    ports:
      - "4173:4173"
    env_file:
      - .env
    restart: always
    depends_on:
      - backend
    networks:
      - default

  mariadb:
    image: mariadb:latest
    restart: always
    environment:
      MARIADB_ROOT_PASSWORD: ${DB_ROOT_PASSWORD:-${DB_PASSWORD:-change_me}}
      MARIADB_DATABASE: ${DB_NAME:-plants_db}
      MARIADB_USER: ${DB_USER:-root}
      MARIADB_PASSWORD: ${DB_PASSWORD:-change_me}
    volumes:
      - mariadb_data:/var/lib/mysql
    healthcheck:
      test: ["CMD-SHELL", "mariadb-admin ping -h localhost -u root -p\"$$MARIADB_ROOT_PASSWORD\""]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s
    networks:
      - db

  redis:
    image: redis:latest
    restart: always
    networks:
      - default

networks:
  db:
    name: pflanzn_db
    internal: true

volumes:
  mariadb_data:
